# ai-digest configuration — copy to .env and fill in
# --- LLM (Google Gemini) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
EMBED_DIM=1536

# --- Database ---
# Local dev (infra/docker-compose.yml):
#   postgresql://aidigest:aidigest@localhost:5432/aidigest
# Supabase: use the SESSION POOLER (Settings > Database > Connection string >
# "Session pooler"), NOT the direct db.<ref>.supabase.co host — that endpoint is
# IPv6-only and unreachable from IPv4-only networks. Pooler user is postgres.<ref>:
#   postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://aidigest:aidigest@localhost:5432/aidigest

# --- Pipeline behavior ---
AIDIGEST_LLM_MOCK=0          # 1 = deterministic mock LLM (no network/key needed; used by tests)
AIDIGEST_DAILY_MAX_ITEMS=15
AIDIGEST_TIMEZONE=America/Los_Angeles
AIDIGEST_WIKI_DIR=          # set to a dir (e.g. ./wiki) to export digests as linked Obsidian notes
AIDIGEST_ENRICH_ACADEMIA=1  # enrich arXiv/HF papers with Semantic Scholar citation velocity
AIDIGEST_WEB_READER=1       # fetch full lab-blog text via Jina Reader when RSS body is thin
AIDIGEST_RELEVANCE_FILTER=1 # hard-drop non-AI stories (HN front page is noisy) via a cheap LLM gate
JUDGE_MODEL=                # weekly best-of-N judge model (blank => same as GEMINI_MODEL)

# --- Optional delivery (leave blank to disable live send) ---
RESEND_API_KEY=
DIGEST_FROM_EMAIL=        # must be an address on a Resend-VERIFIED domain (e.g. you@yourdomain.com)
DIGEST_TO_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=    # echoed back by Telegram on webhook calls (recommended when public)

# --- Academia / community auth (optional; recommended for unattended ingestion) ---
S2_API_KEY=                 # Semantic Scholar API key (works without, just rate-limited)
REDDIT_CLIENT_ID=           # Reddit app-only OAuth (public JSON 403s on servers without it)
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-digest/0.1 (personal news digest)

# --- API security (optional; blank => open, localhost-only) ---
AIDIGEST_API_KEY=           # require X-API-Key on POST /api/feedback and /api/tune
AIDIGEST_LINK_SECRET=       # HMAC-sign email feedback links so they can't be forged
AIDIGEST_PUBLIC_BASE_URL=http://localhost:8000   # base for clickable email links
AIDIGEST_RATE_LIMIT=60      # per-IP requests/min on mutating endpoints (0 = unlimited)

# --- Optional observability (blank = Langfuse disabled; needs `pip install langfuse`) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
